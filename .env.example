# Backend API (same as Helix NEXT_PUBLIC_API_BASE_URL).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Used by:
# - /login → facilities list, admin login, OTP verify (sets helix-session, helix-facility)
# - /api/proxy/analytics → /api/v1/facilities/{id}/usage-metrics

# Cookies (set automatically after login):
#   helix-session  — httpOnly JWT for API proxy
#   helix-facility — optional facility UUID
